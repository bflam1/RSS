      <name>Mend Release Bot</name>
    </author>
    <content type="html">&lt;p local-id="589cc0ef-a2e1-4457-87a3-288dd297fad2"&gt;&lt;strong&gt;New Features and Updates&lt;/strong&gt;&lt;/p&gt;&lt;ul local-id="7a0505d3-5558-4de3-9c82-0d59f54a5073"&gt;&lt;li local-id="2e04036c-5489-4cbf-a79c-aeab79f50fce"&gt;&lt;p local-id="d90989c8-bb55-452e-af90-8b9835befb1e"&gt;Added support for &lt;a class="external-link" href="https://api-docs.mend.io/platform/3.0/applications/createprojectwithsbomscan" rel="nofollow" shape="rect"&gt;SBOM import&lt;/a&gt; via a new API 3.0 endpoint under the Application scope, enabling users to upload SBOM files, automatically create or update projects, and retrieve detailed import logs for improved automation and observability.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p local-id="ee776b8d-8e21-4f5a-8307-2f7b99247bf1"&gt;&lt;strong&gt;Resolved Issues&lt;/strong&gt;&lt;/p&gt;&lt;ul local-id="d8ce27bb-3341-4d9d-bc65-24e8467c15af"&gt;&lt;li local-id="c752cbb9-69a5-40ac-8c8c-73f04aeeb854"&gt;&lt;p local-id="3a66a7a5-ab4c-4d3c-abeb-33701b0f8241"&gt;Fixed an issue where &lt;a data-linked-resource-id="2524152880" data-linked-resource-type="page" data-linked-resource-version="44" href="https://docs.mend.io/integrations/latest/mend-advise-for-visual-studio"&gt;Mend Advise for Visual Studio&lt;/a&gt; was not detecting CVEs. Vulnerabilities are now correctly identified for relevant projects.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;</content>
    <link href="https://docs.mend.io/platform/latest/mend-sca-release-notes"/>
    <published>2025-12-28T00:00:00+00:00</published>
  </entry>
